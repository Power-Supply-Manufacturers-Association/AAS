{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/aas/adc.json",
    "title": "adc",
    "description": "Analog-to-digital converter component data. The presence of the 'adc' field at the top level of an AAS document discriminates the family.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "title": "adcManufacturerInfo",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/name" },
                "reference": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/reference" },
                "status": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/status" },
                "description": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/description" },
                "orderCode": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/orderCode" },
                "datasheetUrl": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/datasheetUrl" },
                "family": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/family" },
                "series": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/series" },
                "spiceModel": { "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/spiceModel" },
                "datasheetInfo": { "$ref": "#/$defs/datasheetInfo" }
            },
            "required": [ "name", "datasheetInfo" ]
        },
        "distributorsInfo": {
            "description": "Where to buy this component.",
            "type": "array",
            "items": { "$ref": "https://psma.com/peas/utils.json#/$defs/distributorInfo" }
        }
    },
    "anyOf": [
        { "required": ["manufacturerInfo"] },
        { "maxProperties": 0 }
    ],
    "$defs": {
        "datasheetInfo": {
            "title": "adcDatasheetInfo",
            "description": "All information extracted from the ADC datasheet.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": { "$ref": "./utils.json#/$defs/part" },
                "electrical": { "$ref": "#/$defs/electrical" },
                "thermal": { "$ref": "./utils.json#/$defs/thermal" },
                "mechanical": { "$ref": "./utils.json#/$defs/mechanical" }
            },
            "required": [ "part", "electrical" ]
        },
        "electrical": {
            "title": "adcElectrical",
            "description": "ADC electricals. The AC trio (SNR, THD, SFDR) lives in the shared converterDynamics block; SINAD and ENOB are DERIVED and never stored. Precision delta-sigma parts that publish a noise chain instead carry effectiveResolution. The analog rail uses the shared supply block; the digital rail is a single voltage.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "resolution": {
                    "description": "Resolution, in bits.",
                    "type": "integer",
                    "minimum": 1
                },
                "sampleRate": {
                    "description": "Maximum sample / throughput / data rate, in samples per second (Hz).",
                    "type": "number",
                    "minimum": 0
                },
                "architecture": {
                    "description": "Conversion architecture.",
                    "type": "string",
                    "enum": [ "SAR", "deltaSigma", "pipeline", "flash", "dualSlope", "folding" ]
                },
                "numberOfChannels": {
                    "description": "Number of analog input channels.",
                    "type": "integer",
                    "minimum": 1
                },
                "inputType": { "$ref": "./utils.json#/$defs/inputType" },
                "integralNonlinearity": {
                    "description": "Integral nonlinearity INL, in LSB.",
                    "type": "number"
                },
                "differentialNonlinearity": {
                    "description": "Differential nonlinearity DNL, in LSB.",
                    "type": "number"
                },
                "offsetError": {
                    "description": "Offset error, in LSB.",
                    "type": "number"
                },
                "gainError": {
                    "description": "Gain error, as a fraction of full scale.",
                    "type": "number"
                },
                "dynamics": {
                    "description": "AC dynamic performance (SNR/THD/SFDR). Present on SAR/pipeline/high-speed parts; absent on DC-precision delta-sigma parts.",
                    "$ref": "./utils.json#/$defs/converterDynamics"
                },
                "effectiveResolution": {
                    "description": "Effective (noise-free-ish) resolution, in bits — the precision delta-sigma figure published in place of SNR/SINAD.",
                    "type": "number",
                    "minimum": 0
                },
                "fullScaleRange": {
                    "description": "Full-scale input range, in V.",
                    "type": "number",
                    "minimum": 0
                },
                "hasProgrammableGainAmplifier": {
                    "description": "True if an input PGA precedes the converter core.",
                    "type": "boolean"
                },
                "referenceSource": { "$ref": "./utils.json#/$defs/referenceSource" },
                "referenceVoltage": {
                    "description": "Reference voltage (internal or nominal external), in V.",
                    "type": "number",
                    "minimum": 0
                },
                "digitalInterface": {
                    "description": "Host data interface(s).",
                    "type": "array",
                    "items": { "$ref": "./utils.json#/$defs/digitalInterface" }
                },
                "supply": {
                    "description": "Analog supply rail.",
                    "$ref": "./utils.json#/$defs/supply"
                },
                "digitalSupplyVoltage": {
                    "description": "Digital / IO supply voltage, in V.",
                    "type": "number"
                },
                "powerConsumption": {
                    "description": "Total power consumption at full rate, in W.",
                    "type": "number",
                    "minimum": 0
                }
            },
            "required": [ "resolution", "architecture" ]
        }
    }
}
