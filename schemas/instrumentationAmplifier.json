{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://psma.com/aas/instrumentationAmplifier.json",
    "title": "instrumentationAmplifier",
    "description": "Instrumentation-amplifier component data. The presence of the 'instrumentationAmplifier' field at the top level of an AAS document discriminates the family.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "manufacturerInfo": {
            "title": "instrumentationAmplifierManufacturerInfo",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/name"
                },
                "reference": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/reference"
                },
                "status": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/status"
                },
                "description": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/description"
                },
                "orderCode": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/orderCode"
                },
                "datasheetUrl": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/datasheetUrl"
                },
                "family": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/family"
                },
                "series": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/series"
                },
                "spiceModel": {
                    "$ref": "https://psma.com/peas/utils.json#/$defs/manufacturerInfo/properties/spiceModel"
                },
                "datasheetInfo": {
                    "$ref": "#/$defs/datasheetInfo"
                }
            },
            "required": [
                "name",
                "datasheetInfo"
            ]
        },
        "distributorsInfo": {
            "description": "Where to buy this component.",
            "type": "array",
            "items": {
                "$ref": "https://psma.com/peas/utils.json#/$defs/distributorInfo"
            }
        }
    },
    "anyOf": [
        {
            "required": [
                "manufacturerInfo"
            ]
        },
        {
            "maxProperties": 0
        }
    ],
    "$defs": {
        "datasheetInfo": {
            "title": "instrumentationAmplifierDatasheetInfo",
            "description": "All information extracted from the instrumentation-amplifier datasheet.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "part": {
                    "$ref": "./utils.json#/$defs/part"
                },
                "electrical": {
                    "$ref": "#/$defs/electrical"
                },
                "thermal": {
                    "$ref": "./utils.json#/$defs/thermal"
                },
                "mechanical": {
                    "$ref": "./utils.json#/$defs/mechanical"
                },
                "pinout": {
                    "description": "Per-pin function map (see utils pinout) — the deciding axis for IC interchangeability: same package does not imply same pinout.",
                    "$ref": "./utils.json#/$defs/pinout"
                },
                "provenance": {
                    "description": "Data-provenance trail (see provenance).",
                    "$ref": "https://psma.com/peas/utils.json#/$defs/provenance"
                }
            },
            "required": [
                "part",
                "electrical"
            ]
        },
        "electrical": {
            "title": "instrumentationAmplifierElectrical",
            "description": "In-amp electricals: amplifierCommon core (single-value headline CMRR, offset, noise, supply) plus the gain-set model and the gain-dependent specs that a single scalar would misrepresent. Bandwidth and CMRR vary strongly with gain, so they are stored as (gain, value) arrays; commonModeRejectionRatio in the core is the headline figure.",
            "allOf": [
                {
                    "$ref": "./utils.json#/$defs/amplifierCommon"
                },
                {
                    "type": "object",
                    "properties": {
                        "gainSetMethod": {
                            "description": "How the gain is programmed.",
                            "type": "string",
                            "enum": [
                                "singleResistor",
                                "fixed",
                                "pinProgrammable",
                                "digitallyProgrammable"
                            ]
                        },
                        "gainEquationConstant": {
                            "description": "Constant k in the gain equation G = 1 + k/R_G, in Ohm (single-resistor parts; e.g. 49400 for AD620).",
                            "type": "number",
                            "minimum": 0
                        },
                        "minimumGain": {
                            "description": "Lowest specified gain, in V/V.",
                            "type": "number",
                            "minimum": 0
                        },
                        "maximumGain": {
                            "description": "Highest specified gain, in V/V.",
                            "type": "number",
                            "minimum": 0
                        },
                        "bandwidthVsGain": {
                            "description": "Small-signal -3 dB bandwidth at each specified gain; value in Hz.",
                            "type": "array",
                            "items": {
                                "$ref": "./utils.json#/$defs/gainPoint"
                            }
                        },
                        "commonModeRejectionRatioVsGain": {
                            "description": "CMRR at each specified gain (DC / low frequency); value in dB.",
                            "type": "array",
                            "items": {
                                "$ref": "./utils.json#/$defs/gainPoint"
                            }
                        },
                        "outputOffsetVoltage": {
                            "description": "Output-referred offset voltage V_OSO, in V (total RTI offset = inputOffsetVoltage + V_OSO/G).",
                            "type": "number",
                            "minimum": 0
                        },
                        "inputCommonModeVoltageRange": {
                            "description": "Input common-mode voltage range, in V.",
                            "$ref": "https://psma.com/peas/utils.json#/$defs/dimensionWithTolerance"
                        },
                        "architecture": {
                            "description": "Internal topology.",
                            "type": "string",
                            "enum": [
                                "threeOpAmp",
                                "twoOpAmp",
                                "currentFeedback",
                                "zeroDrift"
                            ]
                        }
                    }
                }
            ],
            "unevaluatedProperties": false
        }
    }
}
